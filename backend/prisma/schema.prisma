// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  ADMIN
  USER
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  email           String   @unique
  password        String   // hashed
  name            String
  avatarUrl       String
  role            String   @default("USER") // This handles Global Admin vs User
  projects        ProjectMember[]  // list all the projects the user is contributing to 
  createdTask     Task[]   @relation("Reporter")
  assignedTasks   Task[]   @relation("Assignee")
  comments        Comment[]
  notification    Notification[]
  cretedAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum ProjectRole {
  PROJECT_ADMIN
  PROJECT_MEMBER
  PROJECT_VIEWER
}

model project {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String    
  description  String    
  isArchived   Boolean   @default(false)
  members      ProjectMember[]
  boards       Boards[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ProjectMember {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  role      ProjectRole 
  
  userId    String      @db.ObjectId
  user      User        @relation(fields: [userId], references: [id])
  
  projectId String      @db.ObjectId
  project   Project     @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId]) // A user has only one role per project
}


model ProjectMember {
   
}